---
import { projectData } from "../data/projectData.astro";
---

<div class="flex flex-col gap-4">
  {
    projectData.map((project) => (
      <div class="text-xl">
        <div class="lg:flex flex-row items-center gap-2">
          <div>
            <a class="underline decoration-1 decoration-black hover:decoration-2 font-bold" href={project.url}>
              <p>{project.title}</p>
            </a>
          </div>
          <div>
            <p class="text-gray-600 text-lg">{project.technologies}</p>
          </div>
        </div>
        <p class="text-lg">{project.description}</p>
      </div>
    ))
  }
</div>
